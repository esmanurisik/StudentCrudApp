@model StudentCrudApp.Models.Student
@{
    ViewData["Title"] = "Yeni Öğrenci Ekle";
}
<h1>Öğrenci Düzenle</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="LastName" class="control-label"></label>
                <input asp-for="LastName" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Class" class="control-label"></label>
                <input asp-for="Class" class="form-control" />
            </div>
            <div class="form-group mb-4">
                <label asp-for="Number" class="control-label"></label>
                <input asp-for="Number" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Güncelle" class="btn btn-success me-2" />
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>